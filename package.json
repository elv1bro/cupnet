{
  "name": "cupnet",
  "version": "2026.3.29-3",
  "productName": "CupNet",
  "description": "An Electron browser with proxy selection and advanced network logging.",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "debug": "ELECTRON_RUN_AS_NODE= electron --inspect-brk .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "install:from-lock": "npm install --ignore-scripts && npm run rebuild",
    "rebuild:arm64": "arch -arm64 node node_modules/.bin/electron-rebuild -f -w better-sqlite3",
    "rebuild:azuretls": "node scripts/azuretls-electron-rebuild.js",
    "rebuild:azuretls:arm64": "CUPNET_ELECTRON_REBUILD_ARCH=arm64 node scripts/azuretls-electron-rebuild.js",
    "rebuild:azuretls:x64": "CUPNET_ELECTRON_REBUILD_ARCH=x64 node scripts/azuretls-electron-rebuild.js",
    "rebuild:azuretls:universal": "node scripts/azuretls-lipo-universal.js",
    "rebuild:azuretls:node": "node scripts/azuretls-node-rebuild.js",
    "smoke:azuretls-native": "node scripts/smoke-azuretls-native.js",
    "check:native": "npm run rebuild:azuretls && npm run smoke:azuretls-native",
    "check:native:universal": "npm run rebuild:azuretls:universal && CUPNET_SMOKE_REQUIRE_UNIVERSAL=1 npm run smoke:azuretls-native",
    "setup:ffi": "cd ../greengo22 && npm install",
    "test": "bash tests/run-all.sh",
    "test:e2e": "playwright test tests/e2e/",
    "baseline:stability": "node scripts/stability-baseline.js",
    "test:utils": "node tests/test-utils.js",
    "build:guide": "node scripts/build-new-tab-guide.mjs",
    "test:mitm": "node tests/test-mitm.js",
    "test:dns-mitm": "node --test --test-force-exit tests/test-dns-mitm.js",
    "test:db": "ELECTRON_RUN_AS_NODE=1 node_modules/electron/dist/Electron.app/Contents/MacOS/Electron tests/test-db.js",
    "chaos:proxy-sim": "node scripts/chaos-proxy-sim.js",
    "pack": "cross-env USE_HARD_LINKS=false electron-builder --dir",
    "dist": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder",
    "dist:mac": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder --mac dmg",
    "dist:mac:local": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder --mac dmg --publish never",
    "dist:win": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder --win nsis",
    "dist:win:local": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder --win nsis --publish never",
    "dist:linux": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder --linux AppImage",
    "dist:linux:local": "node scripts/ensure-cupnet-node.mjs && cross-env USE_HARD_LINKS=false electron-builder --linux AppImage --publish never",
    "icons:build": "icon-gen -i img.png -o icons --ico --ico-name icon --icns --icns-name icon -r && node -e \"require('fs').copyFileSync('img.png','icons/icon.png')\""
  },
  "author": "Elvi",
  "icon": "img.png",
  "license": "ISC",
  "engines": {
    "node": ">=20 <24",
    "npm": ">=10"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.58.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.0",
    "icon-gen": "^5.0.0",
    "node-addon-api": "^8.3.0",
    "node-gyp": "^10.3.0"
  },
  "overrides": {
    "node-addon-api": "^8.3.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^9.4.3",
    "form-data": "^4.0.0",
    "jsondiffpatch": "^0.7.3",
    "node-forge": "^1.3.3",
    "proxy-chain": "^2.5.9"
  },
  "optionalDependencies": {
    "@2060.io/ffi-napi": "4.0.9",
    "@2060.io/ref-napi": "3.0.6",
    "ref-struct-di": "^1.1.1"
  },
  "build": {
    "afterPack": "./scripts/after-pack-azuretls-worker-native.cjs",
    "appId": "com.cup.net",
    "publish": [
      "github"
    ],
    "asar": true,
    "asarUnpack": [
      "azure-tls-worker.js",
      "network-policy.js",
      "sys-log.js",
      "azuretls/**",
      "node_modules/**"
    ],
    "files": [
      "**/*",
      "!dist",
      "!node_modules/.cache",
      "!azuretls/node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "resources/cupnet-node",
        "to": "cupnet-node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "icons/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "MacOS_CupNet-${version}.${ext}"
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Windows_CupNet-${version}.${ext}"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "artifactName": "Linux_CupNet-${version}.${ext}"
    }
  }
}
