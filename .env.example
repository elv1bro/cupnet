CUPNET_PROXY_URL=<PROXY_URL>
CUPNET_BEARER_TOKEN=<BEARER_TOKEN>
CUPNET_API_BASE_URL=<API_BASE_URL>
CUPNET_CAPTCHA_API_KEY=<CAPTCHA_API_KEY>
CUPNET_GWF_NUMBER=GWF000000000
CUPNET_DEMO_USER=Demo User
CUPNET_ORIGIN=<API_ORIGIN>
CUPNET_REFERER=<API_REFERER>

# Stability policy examples
CUPNET_REQUEST_TIMEOUT_MS=30000
CUPNET_UPSTREAM_REQUEST_TIMEOUT_MS=45000
CUPNET_TLS_HANDSHAKE_TIMEOUT_MS=10000
CUPNET_DB_BUSY_RETRIES=3
CUPNET_DB_WRITE_QUEUE_MAX_HIGH=20000
CUPNET_DB_WRITE_QUEUE_MAX_LOW=5000
CUPNET_RETRY_MAX_RETRIES=2
CUPNET_RETRY_BUDGET_MS=12000
CUPNET_WORKER_MAX_PENDING=5000
CUPNET_WORKER_MAX_INFLIGHT=3000

# Intercept rules (webRequest): по умолчанию фильтр строится из URL правил block/modifyHeaders
# (без глобального <all_urls>), чтобы реже триггерить Cloudflare Turnstile.
# CUPNET_WEBREQUEST_FORCE_ALL_URLS=1 — принудительно один listener на <all_urls> (старое поведение).

# Логи intercept в системную консоль CupNet (Console viewer): снимок правил + каждое срабатывание
# CUPNET_INTERCEPT_LOG_MATCHES=0 — не логировать срабатывания (только снимок правил)
# CUPNET_INTERCEPT_LOG_RULES=0 — не логировать снимок правил при attach/resync
# CUPNET_INTERCEPT_LOG_STDOUT=1 — дублировать те же сообщения в stdout процесса Electron

# Строгие intercept URL: только https?://host/path без *; webRequest без fallback на <all_urls>
# CUPNET_INTERCEPT_STRICT_URLS=1

# Не вешать webRequest onBeforeRequest для traffic-фильтра (блок картинок/CSS) — мешает Cloudflare
# CUPNET_DISABLE_TRAFFIC_WEBREQUEST=1
